    {
      "name": "AsterMarks",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const marks = pm.response.json();\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Marks are not empty\", function () {\r",
              "    pm.expect\r",
              "});\r",
              "\r",
              "pm.test(\"Structure of marks are correct\", function () {\r",
              "    const first = marks[0];\r",
              "    pm.expect(first).to.have.property(\"id\");\r",
              "    pm.expect(first).to.have.property(\"name\");\r",
              "    pm.expect(first).to.have.property(\"code\");\r",
              "    pm.expect(first).to.have.property(\"popular\");\r",
              "    pm.expect(first).to.have.property(\"logo\");\r",
              "    pm.expect(first).to.have.property(\"inCyrillic\");\r",
              "\r",
              "});\r",
              "\r",
              "pm.test(\"Types of data are correct\", function () {\r",
              "    const first = marks[0];\r",
              "    pm.expect(first.id).to.be.a(\"number\");\r",
              "    pm.expect(first.name).to.be.a(\"string\");\r",
              "    pm.expect(first.popular).to.be.a(\"boolean\"); \r",
              "});\r",
              "\r",
              "pm.test(\"Toyota is in the list\", function () {\r",
              "    const toyota = marks.find(mark => mark.name === \"Toyota\");\r",
              "    pm.expect(toyota).to.not.be.undefined;\r",
              "});\r",
              "\r",
              "pm.test(\"GAC is on the list\", function () {\r",
              "   const gac = marks.find(mark => mark.name === \"GAC\");\r",
              "   pm.expect(gac).to.not.be.undefined; \r",
              "});\r",
              "\r",
              "pm.test(\"LADA (ВАЗ) is on the list\", function () {\r",
              "   const lada = marks.find(mark => mark.name === \"LADA (ВАЗ)\");\r",
              "   pm.expect(lada).to.not.be.undefined;\r",
              "});\r",
              "\r",
              "pm.test(\"Response is quicker than 3 sec\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
