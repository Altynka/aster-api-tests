    {
      "name": "Aster countByFilter",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is number\", function () {\r",
              "    const count = parseInt(pm.response.text());\r",
              "    pm.expect(isNaN(count)).to.be.false;\r",
              "});\r",
              "\r",
              "pm.test(\"Count is greater than 0\", function () {\r",
              "    const count = parseInt(pm.response.text());\r",
              "    pm.expect(count).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is quicker than 3 sec\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
