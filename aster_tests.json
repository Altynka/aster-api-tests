    {
      "name": "🔐 Auth Tests",
      "description": "Authentication and authorization tests",
      "item": [
        {
          "name": "POST - Login (Valid credentials)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test(\"[AUTH] Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"[AUTH] Login is successful\", function () {",
                  "    pm.expect(res.msg).to.equal(\"authenticated\");",
                  "});",
                  "",
                  "pm.test(\"[AUTH] Response contains required fields\", function () {",
                  "    pm.expect(res).to.have.property(\"msg\");",
                  "    pm.expect(res).to.have.property(\"id\");",
                  "    pm.expect(res).to.have.property(\"statusCode\");",
                  "});",
                  "",
                  "pm.test(\"[AUTH] Response msg is not an error\", function () {",
                  "    pm.expect(res.msg).to.not.equal(\"error\");",
                  "    pm.expect(res.msg).to.not.equal(\"unauthorized\");",
                  "});",
                  "",
                  "pm.test(\"[AUTH] Response time is acceptable\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Origin", "value": "https://aster.kz", "type": "text" },
              { "key": "Referer", "value": "https://aster.kz/", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"+7 (706) 408-31-32\",\n    \"password\": \"asd123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/rest/login",
              "host": ["{{base_url}}"],
              "path": ["rest", "login"]
            }
          },
          "response": []
        },
