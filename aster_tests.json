    {
      "name": "{{base_url}}/rest/call/autodamu",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();\r",
              "\r",
              "// Тест 1 — сервер отвечает 400 без капчи\r",
              "pm.test(\"Без капчи сервер возвращает 400\", function () {\r",
              "    pm.response.to.have.status(400);\r",
              "});\r",
              "\r",
              "// Тест 2 — структура ответа есть\r",
              "pm.test(\"Ответ содержит поле msg\", function () {\r",
              "    pm.expect(res).to.have.property(\"msg\");\r",
              "});\r",
              "\r",
              "// Тест 3 — сообщение об ошибке капчи\r",
              "pm.test(\"Сообщение об ошибке reCAPTCHA\", function () {\r",
              "    pm.expect(res.msg).to.equal(\"Неверный reCAPTCHA\");\r",
              "});\r",
              "\r",
              "// Тест 4 — время ответа\r",
              "pm.test(\"Ответ быстрее 3 секунд\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
