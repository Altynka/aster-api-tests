    {
      "name": "🚗 Catalog Tests",
      "description": "Tests for car catalog, marks and models",
      "item": [
        {
          "name": "GET - All Car Marks (Used cars)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const marks = pm.response.json();",
                  "",
                  "pm.test(\"[CATALOG] Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"[CATALOG] Marks list is not empty\", function () {",
                  "    pm.expect(marks.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test(\"[CATALOG] Mark has required fields\", function () {",
                  "    const first = marks[0];",
                  "    pm.expect(first).to.have.property(\"id\");",
                  "    pm.expect(first).to.have.property(\"name\");",
                  "    pm.expect(first).to.have.property(\"code\");",
                  "    pm.expect(first).to.have.property(\"popular\");",
                  "    pm.expect(first).to.have.property(\"logo\");",
                  "    pm.expect(first).to.have.property(\"inCyrillic\");",
                  "});",
                  "",
                  "pm.test(\"[CATALOG] Data types are correct\", function () {",
                  "    const first = marks[0];",
                  "    pm.expect(first.id).to.be.a(\"number\");",
                  "    pm.expect(first.name).to.be.a(\"string\");",
                  "    pm.expect(first.popular).to.be.a(\"boolean\");",
                  "});",
                  "",
                  "pm.test(\"[CATALOG] Toyota is in the list\", function () {",
                  "    const toyota = marks.find(m => m.name === \"Toyota\");",
                  "    pm.expect(toyota).to.not.be.undefined;",
                  "});",
                  "",
                  "pm.test(\"[CATALOG] LADA is in the list\", function () {",
                  "    const lada = marks.find(m => m.name === \"LADA (ВАЗ)\");",
                  "    pm.expect(lada).to.not.be.undefined;",
                  "});",
                  "",
                  "pm.test(\"[CATALOG] Used car marks have inCyrillic field\", function () {",
                  "    const withCyrillic = marks.filter(m => m.inCyrillic !== null);",
                  "    pm.expect(withCyrillic.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test(\"[CATALOG] Response time is acceptable\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Origin", "value": "https://aster.kz", "type": "text" },
              { "key": "Referer", "value": "https://aster.kz/", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/dict/marks/v2",
              "host": ["{{base_url}}"],
              "path": ["dict", "marks", "v2"]
            }
          },
          "response": []
        },
        {
          "name": "GET - New Car Marks",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const marks = pm.response.json();",
                  "",
                  "pm.test(\"[CATALOG] Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"[CATALOG] New marks list is not empty\", function () {",
                  "    pm.expect(marks.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test(\"[CATALOG] Mark has required fields\", function () {",
                  "    const first = marks[0];",
                  "    pm.expect(first).to.have.property(\"id\");",
                  "    pm.expect(first).to.have.property(\"name\");",
                  "    pm.expect(first).to.have.property(\"code\");",
                  "    pm.expect(first).to.have.property(\"logo\");",
                  "});",
                  "",
                  "pm.test(\"[CATALOG] Data types are correct\", function () {",
                  "    const first = marks[0];",
                  "    pm.expect(first.id).to.be.a(\"number\");",
                  "    pm.expect(first.name).to.be.a(\"string\");",
                  "    pm.expect(first.code).to.be.a(\"string\");",
                  "});",
                  "",
                  "pm.test(\"[CATALOG] Every mark has a valid logo URL\", function () {",
                  "    marks.forEach(function(mark) {",
                  "        pm.expect(mark.logo).to.not.be.null;",
                  "        pm.expect(mark.logo).to.include(\"https://\");",
                  "    });",
                  "});",
                  "",
                  "pm.test(\"[CATALOG] LADA is in new cars list\", function () {",
                  "    const lada = marks.find(m => m.code === \"VAZ\");",
                  "    pm.expect(lada).to.not.be.undefined;",
                  "});",
                  "",
                  "pm.test(\"[CATALOG] New car marks have inCyrillic as null\", function () {",
                  "    marks.forEach(function(mark) {",
                  "        pm.expect(mark.inCyrillic).to.be.null;",
                  "    });",
                  "});",
                  "",
                  "pm.test(\"[CATALOG] Response time is acceptable\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Origin", "value": "https://aster.kz", "type": "text" },
              { "key": "Referer", "value": "https://aster.kz/", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/dict/marks/new/v2",
              "host": ["{{base_url}}"],
              "path": ["dict", "marks", "new", "v2"]
            }
          },
          "response": []
        }
      ]
