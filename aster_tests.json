  "item": [
    {
      "name": "🔥 Smoke Tests",
      "description": "Basic tests to verify the API is up and running",
      "item": [
        {
          "name": "GET - All Car Marks",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const marks = pm.response.json();",
                  "",
                  "pm.test(\"[SMOKE] Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"[SMOKE] Marks list is not empty\", function () {",
                  "    pm.expect(marks.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test(\"[SMOKE] Response time is acceptable\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Origin", "value": "https://aster.kz", "type": "text" },
              { "key": "Referer", "value": "https://aster.kz/", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/dict/marks/v2",
              "host": ["{{base_url}}"],
              "path": ["dict", "marks", "v2"]
            }
          },
          "response": []
        },
        {
          "name": "POST - Total Cars Count",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const count = parseInt(pm.response.text());",
                  "",
                  "pm.test(\"[SMOKE] Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"[SMOKE] Response is a valid number\", function () {",
                  "    pm.expect(isNaN(count)).to.be.false;",
                  "});",
                  "",
                  "pm.test(\"[SMOKE] Cars count is greater than 0\", function () {",
                  "    pm.expect(count).to.be.above(0);",
                  "});",
                  "",
                  "pm.test(\"[SMOKE] Cars count is realistic (less than 1M)\", function () {",
                  "    pm.expect(count).to.be.below(1000000);",
                  "});",
                  "",
                  "pm.test(\"[SMOKE] Response time is acceptable\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Origin", "value": "https://aster.kz", "type": "text" },
              { "key": "Referer", "value": "https://aster.kz/", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"creditFilter\": false,\n    \"carPathType\": null,\n    \"catalog_filter\": [\"\"],\n    \"yearFrom\": null,\n    \"yearTo\": null,\n    \"priceFrom\": null,\n    \"priceTo\": null,\n    \"mileageFrom\": null,\n    \"mileageTo\": null,\n    \"city\": null,\n    \"customClear\": false,\n    \"promo\": false,\n    \"bonus\": false,\n    \"underMarketPrice\": false,\n    \"credit44\": false,\n    \"nauryz\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/rest/ads/countByFilter",
              "host": ["{{base_url}}"],
              "path": ["rest", "ads", "countByFilter"]
            }
          },
          "response": []
        }
      ]
